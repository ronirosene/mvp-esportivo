generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ORGANIZADOR
}

enum EventStatus {
  PLANEJAMENTO
  EM_ANDAMENTO
  FINALIZADO
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  FINISHED
  CANCELLED
}

enum Fase {
  GRUPOS
  QUARTAS
  SEMIFINAL
  FINAL
  TERCEIRO_LUGAR
}

enum InscricaoStatus {
  INSCRITO
  CONFIRMADO
  DESISTENTE
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  nome      String
  email     String   @unique
  senha     String
  role      Role     @default(ORGANIZADOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id         String      @id @default(uuid()) @db.Uuid
  nome       String
  ano        Int
  cidadeSede String
  dataInicio DateTime   @db.Date
  dataFim    DateTime   @db.Date
  status     EventStatus @default(PLANEJAMENTO)
  logoUrl    String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  eventSports EventSport[]
  teams       Team[]
}

model Sport {
  id        String   @id @default(uuid()) @db.Uuid
  nome      String
  categoria String
  createdAt DateTime @default(now())

  eventSports EventSport[]
  teams       Team[]
}

model EventSport {
  id        String   @id @default(uuid()) @db.Uuid
  eventId   String   @db.Uuid
  sportId   String   @db.Uuid
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sport Sport @relation(fields: [sportId], references: [id], onDelete: Restrict)

  eventSportCities EventSportCity[]
  groups           Group[]
  matches          Match[]

  @@unique([eventId, sportId])
}

model EventSportCity {
  id           String          @id @default(uuid()) @db.Uuid
  eventSportId String          @db.Uuid
  cityId       String          @db.Uuid
  status       InscricaoStatus @default(INSCRITO)
  createdAt    DateTime        @default(now())

  eventSport       EventSport       @relation(fields: [eventSportId], references: [id], onDelete: Cascade)
  city             City             @relation(fields: [cityId], references: [id], onDelete: Restrict)
  groupParticipant GroupParticipant?

  @@unique([eventSportId, cityId])
}

model City {
  id          String   @id @default(uuid()) @db.Uuid
  nome        String
  estado      String
  siglaEstado String
  brasaoUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  eventSportCities EventSportCity[]
  teams            Team[]
  homeMatches      Match[]         @relation("homeMatches")
  awayMatches      Match[]         @relation("awayMatches")

  @@unique([nome, siglaEstado])
}

model Team {
  id        String   @id @default(uuid()) @db.Uuid
  eventId   String   @db.Uuid
  cityId    String   @db.Uuid
  sportId   String   @db.Uuid
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  city  City  @relation(fields: [cityId], references: [id], onDelete: Restrict)
  sport Sport @relation(fields: [sportId], references: [id], onDelete: Restrict)

  @@unique([eventId, cityId, sportId])
}

model Group {
  id            String   @id @default(uuid()) @db.Uuid
  nome          String
  eventSportId  String   @db.Uuid
  createdAt     DateTime @default(now())

  eventSport EventSport @relation(fields: [eventSportId], references: [id], onDelete: Cascade)

  groupParticipants GroupParticipant[]
  matches           Match[]

  @@unique([nome, eventSportId])
}

model GroupParticipant {
  id               String   @id @default(uuid()) @db.Uuid
  groupId          String   @db.Uuid
  eventSportCityId String   @db.Uuid @unique
  createdAt        DateTime @default(now())

  group          Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  eventSportCity EventSportCity @relation(fields: [eventSportCityId], references: [id], onDelete: Cascade)
}

model Match {
  id           String       @id @default(uuid()) @db.Uuid
  groupId      String       @db.Uuid
  eventSportId String       @db.Uuid
  homeCityId   String       @db.Uuid
  awayCityId   String       @db.Uuid
  matchDate    DateTime?
  location     String?
  homeScore    Int?
  awayScore    Int?
  status       MatchStatus  @default(SCHEDULED)
  fase         Fase         @default(GRUPOS)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  group      Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  eventSport EventSport @relation(fields: [eventSportId], references: [id], onDelete: Cascade)
  homeCity   City       @relation("homeMatches", fields: [homeCityId], references: [id], onDelete: Restrict)
  awayCity   City       @relation("awayMatches", fields: [awayCityId], references: [id], onDelete: Restrict)
}
