# ─── Postgres ──────────────────────────────────────
POSTGRES_USER=mvp
POSTGRES_PASSWORD=mvppass
POSTGRES_DB=mvpdatabase
POSTGRES_PORT=5432

# ─── Backend ───────────────────────────────────────
DATABASE_URL="postgresql://mvp:mvppass@localhost:5432/mvpdatabase?schema=public"
BACKEND_PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── Frontend ──────────────────────────────────────
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Deploy ─────────────────────────────────────────
# Exemplo para Neon:
# DATABASE_URL="postgresql://user:pass@us-east-1.aws.neon.tech/neondb?sslmode=require"

# Exemplo para Supabase:
# DATABASE_URL="postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres"

# Exemplo para Railway:
# DATABASE_URL="postgresql://user:pass@containername.railway.app:5432/railway"
